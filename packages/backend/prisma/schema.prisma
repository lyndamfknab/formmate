generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    String
  content   String
  role      String   // 'user' or 'assistant'
  createdAt DateTime @default(now())
}

model AiResponseLog {
  id           Int      @id @default(autoincrement())
  orchestrator String
  response     String
  timestamp    DateTime @default(now())
}
