generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    String
  content   String
  role      String   // 'user' or 'assistant'
  payload   String?  // JSON stringified metadata
  createdAt DateTime @default(now())
}

model AiResponseLog {
  id           Int      @id @default(autoincrement())
  handler      String
  providerName String?  // 'openai' | 'gemini' etc.
  modelName    String?  // 'gpt-5.2' | 'gemini-3-flash' etc.
  input        String?  // Full prompt (system + developer + user)
  response     String
  schemaId     String?
  timestamp    DateTime @default(now())
}

model SystemSetting {
  key   String @id
  value String
}

model DesignStyle {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  displayName  String
  description  String   @default("")
  listPrompt   String   @default("")
  detailPrompt String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model AgentTask {
  id        Int      @id @default(autoincrement())
  status    String   @default("pending") // 'pending' | 'finished'
  items     String   // JSON stringified AgentTaskItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
