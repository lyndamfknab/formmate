{
    "name": "formmate",
    "private": true,
    "workspaces": [
        "packages/*",
        "packages/sdk",
        "packages/admin",
        "packages/portal"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev:service\" \"npm run dev:ui\"",
        "dev:service": "npm run dev --workspace=@formmate/service",
        "debug:service": "npm run debug --workspace=@formmate/service",
        "dev:ui": "npm run dev --workspace=@formmate/ui",
        "dev:admin": "npm run dev --workspace=@formmate/admin",
        "dev:portal": "npm run dev --workspace=@formmate/portal",
        "build:shared": "npm run build --workspace=@formmate/shared",
        "install:all": "npm install"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    },
    "dependencies": {
        "@fastify/static": "^9.0.0"
    }
}